# ── Server ────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated list of origins allowed by CORS. Default is the Vite dev server.
CORS_ORIGIN=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────
# SQLite for the demo. Prisma reads this as the connection string.
DATABASE_URL="file:./dev.db"

# ── Chain ────────────────────────────────────────────────────────────
# Sepolia is the only enabled chain right now.
SEPOLIA_RPC_URL=https://sepolia.gateway.tenderly.co
SEPOLIA_PAYMENT_GATEWAY_ADDRESS=

# Block to start indexing from. Leave blank to start from the current head
# (events before this point won't be backfilled). For an existing deployment,
# set this to the deployment block to backfill the entire history.
SEPOLIA_INDEXER_START_BLOCK=

# Polling interval (ms) for the live indexer. Sepolia blocks every ~12s,
# so 6000 gets close to instant without hammering the RPC.
INDEXER_POLL_MS=6000

# Known stablecoin addresses on Sepolia. The indexer uses these to resolve
# the `token` field on PaymentReceived/DepositReceived events back to a
# symbol the frontend understands. Leave blank for tokens you haven't
# deployed yet — events involving those tokens will be skipped with a warn.
SEPOLIA_USDC_ADDRESS=
SEPOLIA_USDT_ADDRESS=
SEPOLIA_DAI_ADDRESS=

# ── Demo auth ────────────────────────────────────────────────────────
# DEMO ONLY: requests authenticate by sending the x-merchant-address header.
# In production swap this for SIWE / EIP-4361 signature verification.
TRUSTED_HEADER_AUTH=true
