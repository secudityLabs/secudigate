# WalletConnect / Reown project ID. REQUIRED — get a free one in 2 minutes at
# https://cloud.reown.com (formerly cloud.walletconnect.com). RainbowKit v2+
# no longer ships an embedded demo id, so leaving this blank crashes the app
# at runtime with "No projectId found".
VITE_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC. If blank the frontend falls through to public endpoints.
# Restricted networks should set this explicitly to an endpoint they can reach.
VITE_SEPOLIA_RPC_URL=

# Smart contract + mock token addresses printed by:
#   forge script script/Deploy.s.sol:Deploy --rpc-url $SEPOLIA_RPC_URL --broadcast
VITE_PAYMENT_GATEWAY_ADDRESS=
VITE_USDC_ADDRESS=
VITE_USDT_ADDRESS=
VITE_DAI_ADDRESS=

# Backend API base URL.
# - LEAVE BLANK for "public demo" mode: the app runs frontend-only against
#   localStorage. No data leaves the visitor's browser. Recommended for
#   Vercel/Cloudflare-Pages deploys when you aren't hosting the backend.
# - Set to http://localhost:4000 for local full-stack dev.
# - Set to https://api.your-host for a production deploy with the backend.
VITE_API_BASE_URL=
